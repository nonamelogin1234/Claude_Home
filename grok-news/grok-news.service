[Unit]
Description=Grok News + Health Stats Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/grok-news
EnvironmentFile=/opt/grok-news/.env
ExecStart=/usr/bin/python3 /opt/grok-news/server.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
