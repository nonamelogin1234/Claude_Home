server {
    listen 443 ssl;
    server_name home.myserver-ai.ru;

    ssl_certificate /etc/letsencrypt/live/home.myserver-ai.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/home.myserver-ai.ru/privkey.pem;

    location /authelia {
        internal;
        proxy_pass http://127.0.0.1:9091/api/verify;
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
        proxy_set_header X-Original-URL $scheme://$http_host$request_uri;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        auth_request /authelia;
        auth_request_set $target_url $scheme://$http_host$request_uri;
        error_page 401 =302 https://auth.myserver-ai.ru/?rd=$target_url;

        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 80;
    server_name home.myserver-ai.ru;
    return 301 https://$host$request_uri;
}
